# Git ignore for research project

# Output directories (not committed)
outputs/
!outputs/.gitkeep

# Python artifacts
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.venv/
venv/
ENV/
env/
.env/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Temporary files
*.tmp
temp/

# Binary files (Office documents, PDFs)
*.docx
*.pdf
*.pptx
*.xlsx

# Data files (add manually if needed)
data/raw/
data/processed/*.csv
data/processed/*.parquet

# Local-only development artifacts (SOTA CLEANUP)
local_only/
.gemini/
.qwen/
.pytest_cache/
.ruff_cache/
.hypothesis/
.streamlit/config.toml

# Legacy exclusions (for safety)
conductor/
context/reflexive_journal/
docs/expert_reviews/
docs/EXTERNAL_VALIDATION_ACTION_LOG.md

# Posterior samples (large files)
outputs/posterior_samples/*.npy
outputs/posterior_samples/*.csv

# Run manifests (keep structure, not content)
outputs/runs/
